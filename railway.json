{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build -w craftlauncher-user-web"
  },
  "deploy": {
    "startCommand": "npm run start -w craftlauncher-user-web",
    "restartPolicyType": "ON_FAILURE"
  }
}
