# URL del admin API (backend de cuentas + portal)
ADMIN_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3000

# Misma clave que en el admin — cifra/descifra acceso_portal (mín. 16 caracteres)
# Genera: openssl rand -base64 24
PORTAL_CLIPBOARD_SECRET=cambia-esto-misma-clave-en-admin-y-user-web

# Railway — segundo servicio (root: packages/user_web, ver railway.json)
# ADMIN_API_URL=https://tu-admin.up.railway.app
# NEXT_PUBLIC_ADMIN_API_URL=https://tu-admin.up.railway.app
# PORTAL_CLIPBOARD_SECRET=(misma clave que en el servicio admin, mín. 16 chars)
#
# El BFF (/api/portal, /api/portal/chat, /api/auth/*) llama al admin en servidor;
# en producción ADMIN_API_URL NO puede ser localhost (isAdminApiUrlMissingForDeploy).

# Puerto (Railway inyecta PORT automáticamente)
# PORT=3003
